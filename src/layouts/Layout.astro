---
import { getCollection } from 'astro:content';
import NavBar from '../components/NavBar.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { BASE, SITE } from '../config';
import { getBreadcrumb } from '../utils/breadcrumb';
import { sortByDateDesc } from '../utils/date';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const blogEntries = sortByDateDesc((await getCollection('blog')).filter((e) => !e.data.draft)).map((entry) => {
  return {
    id: entry.id, // Full path like 'science/human-body/article.md'
    slug: entry.slug, // Full slug like 'science/human-body/article'
    title: entry.data.title,
    date: entry.data.date,
    section: entry.data.section, // Still support frontmatter override
  };
});

const pages = (await getCollection('pages')).filter((e) => !e.data.draft);
const mainEntry = pages.find((e) => e.slug === 'main');
const aboutEntry = pages.find((e) => e.slug === 'about-me');

const mainForSidebar = mainEntry ? { slug: mainEntry.slug, title: mainEntry.data.title, date: mainEntry.data.date } : null;
const aboutForSidebar = aboutEntry ? { slug: aboutEntry.slug, title: aboutEntry.data.title, date: aboutEntry.data.date } : null;
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const desc = description ?? SITE.description;
const breadcrumbPath = getBreadcrumb(Astro.url.pathname);
---

<!doctype html>
<html lang="ru">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <meta id="theme-color-meta" name="theme-color" content="#13161f" />
    <link rel="icon" type="image/svg+xml" href={`${BASE}favicon.svg`} />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap" rel="stylesheet" />
    <link id="chroma-light" rel="stylesheet" href={`${BASE}css/chroma-github.css`} />
    <link id="chroma-dark" rel="stylesheet" href={`${BASE}css/chroma-github-dark.css`} disabled />
    
    <script is:inline>
      (function() {
        const theme = localStorage.getItem('theme') || (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
        document.documentElement.dataset.theme = theme;

        const themeColorMeta = document.getElementById('theme-color-meta');
        if (themeColorMeta) {
          themeColorMeta.setAttribute('content', theme === 'dark' ? '#13161f' : '#ffffff');
        }
        
        const font = localStorage.getItem('font-size') || 'md';
        document.documentElement.dataset.font = font;
      })();
    </script>
  </head>
  <body>
    <div class="app-layout">
      <NavBar breadcrumbPath={breadcrumbPath} />
      <div class="main-container">
        <div class="main-grid">
          <aside id="layout-sidebar">
            <Sidebar blogEntries={blogEntries} mainEntry={mainForSidebar} aboutEntry={aboutForSidebar} />
          </aside>
          <main>
            <slot />
          </main>
        </div>
        <Footer />
      </div>
    </div>

    <script defer src={`${BASE}theme.js`}></script>
  </body>
</html>
