---
import { getCollection } from 'astro:content';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Sidebar from '../components/Sidebar.astro';
import { SITE } from '../config';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description } = Astro.props;

const allEntries = (await getCollection('blog')).filter((e) => !e.data.draft);

const blogEntries = allEntries
  .filter((e) => e.data.section === 'dev' || e.data.section === 'life')
  .map((entry) => ({
    slug: entry.slug,
    title: entry.data.title,
    date: entry.data.date,
    section: entry.data.section as 'dev' | 'life',
  }));

const mainEntry = allEntries.find((e) => e.slug === 'main' || e.data.section === 'main');
const aboutEntry = allEntries.find((e) => e.slug === 'about-me' || e.data.section === 'about');

const mainForSidebar = mainEntry ? { slug: mainEntry.slug, title: mainEntry.data.title, date: mainEntry.data.date } : null;
const aboutForSidebar = aboutEntry ? { slug: aboutEntry.slug, title: aboutEntry.data.title, date: aboutEntry.data.date } : null;

const BASE = import.meta.env.BASE_URL;
const fullTitle = title === SITE.title ? title : `${title} | ${SITE.title}`;
const desc = description ?? SITE.description;

function getBreadcrumb(pathname: string): string {
  const p = pathname.replace(/\/$/, '') || '/';
  if (p === '/') return 'main.md';
  if (p === '/about-me') return 'about-me.md';
  if (p === '/blog') return 'blog/';
  const blogSectionMatch = p.match(/^\/blog\/(dev|life)\/?$/);
  if (blogSectionMatch) return `blog/${blogSectionMatch[1]}/`;
  const slugMatch = p.match(/^\/blog\/(dev|life)\/([^/]+)$/);
  if (slugMatch) return `blog/${slugMatch[1]}/${slugMatch[2]}.md`;
  return p.slice(1).replace(/\//g, '/') || 'content';
}
const breadcrumbPath = getBreadcrumb(Astro.url.pathname);
---

<!doctype html>
<html lang="ru" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="color-scheme" content="light dark" />
    <title>{fullTitle}</title>
    <meta name="description" content={desc} />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css" />
    <script is:inline define:vars={{}}>
      (function () {
        var root = document.documentElement;
        try {
          var storedTheme = localStorage.getItem("theme");
          var systemDark = window.matchMedia && window.matchMedia("(prefers-color-scheme: dark)").matches;
          root.dataset.theme = storedTheme || (systemDark ? "dark" : "light");
          var fontSize = localStorage.getItem("fontSize");
          if (fontSize === "s" || fontSize === "m" || fontSize === "l") root.dataset.fontSize = fontSize;
          else root.dataset.fontSize = "m";
        } catch (_) {
          root.dataset.theme = "light";
          root.dataset.fontSize = "m";
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,600;0,700&display=swap" rel="stylesheet" />
    <link id="chroma-light" rel="stylesheet" href={`${BASE}css/chroma-github.css`} />
    <link id="chroma-dark" rel="stylesheet" href={`${BASE}css/chroma-github-dark.css`} disabled />
    <script is:inline>
      (function () {
        var isDark = document.documentElement.dataset.theme === "dark";
        var light = document.getElementById("chroma-light");
        var dark = document.getElementById("chroma-dark");
        if (light && dark) {
          light.disabled = isDark;
          dark.disabled = !isDark;
        }
      })();
    </script>
  </head>
  <body>
    <Header />
    <div class="layout-body">
      <div class="top-bar-breadcrumb" role="banner">
        <span class="top-bar-text">content/</span>
        <span class="top-bar-sep" aria-hidden="true"> · </span>
        <span class="top-bar-path">{breadcrumbPath}</span>
        <div class="theme-controls-in-bar" aria-label="Размер шрифта и тема">
          <span class="font-size-controls" aria-label="Размер шрифта">
            <button id="font-size-decrease" type="button" class="font-size-btn" aria-label="Уменьшить шрифт">A−</button>
            <button id="font-size-increase" type="button" class="font-size-btn" aria-label="Увеличить шрифт">A+</button>
          </span>
          <button id="theme-toggle" type="button" class="theme-btn theme-btn-icon" aria-label="Переключить тему">
            <span class="theme-icon theme-icon-sun" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg></span>
            <span class="theme-icon theme-icon-moon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg></span>
          </button>
        </div>
      </div>
      <div class="layout-vscode">
        <aside class="layout-sidebar" id="layout-sidebar">
          <Sidebar blogEntries={blogEntries} mainEntry={mainForSidebar} aboutEntry={aboutForSidebar} />
        </aside>
        <div class="layout-content-col">
          <main class="site-main layout-main">
            <slot />
          </main>
          <Footer />
        </div>
      </div>
    </div>

    <script defer src={`${BASE}theme.js`}></script>
  </body>
</html>
