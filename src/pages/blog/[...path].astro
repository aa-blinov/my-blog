---
import Layout from '../../layouts/Layout.astro';
import PostList from '../../components/PostList.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import { sortByDateDesc } from '../../utils/date';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  
  // 1. Routes for individual files
  const filePaths = entries.map((entry) => ({
    params: { path: entry.slug },
    props: { kind: 'file', entry },
  }));

  // 2. Routes for folders (directories)
  const directoryPaths = new Set();
  entries.forEach((entry) => {
    const parts = entry.slug.split('/');
    // Add all parent paths
    for (let i = 1; i < parts.length; i++) {
      directoryPaths.add(parts.slice(0, i).join('/'));
    }
  });

  const folderPaths = Array.from(directoryPaths).map((path) => ({
    params: { path: path as string },
    props: { kind: 'folder', path: path as string },
  }));

  return [...filePaths, ...folderPaths];
}

const { kind, entry, path } = Astro.props;

// If it's a file, pre-render the content
let Content = null;
if (kind === 'file') {
  const rendered = await entry.render();
  Content = rendered.Content;
}

// If it's a folder, find all entries that start with this path
let folderEntries = [];
if (kind === 'folder') {
  const allEntries = await getCollection('blog');
  folderEntries = sortByDateDesc(
    allEntries.filter((e) => !e.data.draft && e.slug.startsWith(path + '/'))
  );
}

const title = kind === 'file' ? entry.data.title : (path.split('/').pop() || path);
---

{kind === 'file' ? (
  <Layout title={entry.data.title} description={entry.data.summary}>
    <article>
      <header>
        <p class="meta">{formatDate(entry.data.date)} · {entry.id}</p>
        <hgroup>
          <h1>{entry.data.title}</h1>
          {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
        </hgroup>
      </header>
      <div class="content">
        <Content />
      </div>
    </article>
  </Layout>
) : (
  <Layout title={title}>
    <article>
      <header>
        <hgroup>
          <h1>{title}</h1>
          <p>Раздел: {path}</p>
        </hgroup>
      </header>
      <h2>Статьи в этом разделе</h2>
      <PostList posts={folderEntries} sectionTitle={title} />
    </article>
  </Layout>
)}
