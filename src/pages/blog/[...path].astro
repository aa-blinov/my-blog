---
import Layout from '../../layouts/Layout.astro';
import PostList from '../../components/PostList.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../utils/date';
import { sortByDateDesc } from '../../utils/date';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  
  // 1. Routes for individual files
  const filePaths = entries.map((entry) => ({
    params: { path: entry.slug },
    props: { kind: 'file', entry },
  }));

  // 2. Routes for folders (directories)
  const directoryPaths = new Set();
  entries.forEach((entry) => {
    const parts = entry.slug.split('/');
    // Add all parent paths
    for (let i = 1; i < parts.length; i++) {
      directoryPaths.add(parts.slice(0, i).join('/'));
    }
  });

  const folderPaths = Array.from(directoryPaths).map((path) => ({
    params: { path: path as string },
    props: { kind: 'folder', path: path as string },
  }));

  return [...filePaths, ...folderPaths];
}

const { kind, entry, path } = Astro.props;

// If it's a file, pre-render the content
let Content = null;
if (kind === 'file') {
  const rendered = await entry.render();
  Content = rendered.Content;
}

// If it's a folder, find all entries and group them
interface Group {
  name: string;
  entries: any[];
  maxDate: number;
}
let directEntries = [];
let subGroups: Group[] = [];

if (kind === 'folder') {
  const allEntries = await getCollection('blog');
  const entriesInFolder = allEntries.filter((e) => !e.data.draft && e.slug.startsWith(path + '/'));
  
  const groups: Record<string, any[]> = {};
  
  entriesInFolder.forEach(entry => {
    const relativeSlug = entry.slug.slice(path.length + 1);
    const parts = relativeSlug.split('/');
    if (parts.length === 1) {
      directEntries.push(entry);
    } else {
      const sub = parts[0];
      if (!groups[sub]) groups[sub] = [];
      groups[sub].push(entry);
    }
  });

  directEntries = sortByDateDesc(directEntries);
  subGroups = Object.entries(groups)
    .map(([name, entries]) => ({ 
      name, 
      entries: sortByDateDesc(entries),
      maxDate: Math.max(...entries.map(e => e.data.date.getTime()))
    }))
    .sort((a, b) => a.name.localeCompare(b.name)); // Sort sections alphabetically
}

const title = kind === 'file' ? entry.data.title : (path.split('/').pop() || path);
---

{kind === 'file' ? (
  <Layout title={entry.data.title} description={entry.data.summary}>
    <article>
      <header>
        <p class="meta">{formatDate(entry.data.date)} · {entry.id}</p>
        <hgroup>
          <h1>{entry.data.title}</h1>
          {entry.data.summary && <p class="summary">{entry.data.summary}</p>}
        </hgroup>
      </header>
      <div class="content">
        <Content />
      </div>
    </article>
  </Layout>
) : (
  <Layout title={title}>
    <article>
      <header>
        <hgroup>
          <h1>{title}</h1>
          <p>Раздел: {path}</p>
        </hgroup>
      </header>
      
      {directEntries.length > 0 && (
        <section style="margin-top: 2rem">
          <header style="margin-bottom: 2rem;">
            <h2 style="margin: 0; display: flex; align-items: center; gap: 0.75rem; font-size: 1.5rem; border: none; padding: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 1.75rem; height: 1.75rem; color: var(--pico-primary);">
                <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15ZM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146Z" />
              </svg>
              /
            </h2>
          </header>
          <PostList posts={directEntries} />
        </section>
      )}
      {subGroups.map((group, index) => (
        <section style="margin-top: 3rem">
          {(index > 0 || directEntries.length > 0) && <hr style="margin-bottom: 3rem; opacity: 0.3;" />}
          <header style="margin-bottom: 2rem;">
            <h2 style="margin: 0; display: flex; align-items: center; gap: 0.75rem; font-size: 1.5rem; border: none; padding: 0;">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" style="width: 1.75rem; height: 1.75rem; color: var(--pico-primary);">
                <path d="M19.5 21a3 3 0 0 0 3-3v-4.5a3 3 0 0 0-3-3h-15a3 3 0 0 0-3 3V18a3 3 0 0 0 3 3h15ZM1.5 10.146V6a3 3 0 0 1 3-3h5.379a2.25 2.25 0 0 1 1.59.659l2.122 2.121c.14.141.331.22.53.22H19.5a3 3 0 0 1 3 3v1.146A4.483 4.483 0 0 0 19.5 9h-15a4.483 4.483 0 0 0-3 1.146Z" />
              </svg>
              {group.name}
            </h2>
          </header>
          <PostList posts={group.entries} />
        </section>
      ))}
    </article>
  </Layout>
)}
