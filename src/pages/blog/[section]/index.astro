---
import Layout from '../../../layouts/Layout.astro';
import PostList from '../../../components/PostList.astro';
import { getCollection } from 'astro:content';
import { BLOG_SECTIONS, SECTION_DESCRIPTIONS, SECTION_TITLES } from '../../../config';
import { sortByDateDesc } from '../../../utils/date';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  const sections = [...new Set(entries.map((e) => e.data.section).filter((s) => BLOG_SECTIONS.includes(s)))];
  return sections.map((section) => ({ params: { section } }));
}

const { section } = Astro.params;
if (!section) throw new Error('section is required');

const posts = sortByDateDesc((await getCollection('blog')).filter((p) => !p.data.draft && p.data.section === section));
const title = SECTION_TITLES[section] ?? section;
const description = SECTION_DESCRIPTIONS[section] ?? '';
---

<Layout title={title}>
  <article>
    <header>
      <hgroup>
        <h1>{title}</h1>
        {description && <p>{description}</p>}
      </hgroup>
    </header>
    <h2>Свежие статьи</h2>
    <PostList posts={posts} sectionTitle={title} />
  </article>
</Layout>
