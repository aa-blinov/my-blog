---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SECTION_TITLES } from '../../../config';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries
    .filter((e) => !e.data.draft && (e.data.section === 'dev' || e.data.section === 'life'))
    .map((entry) => ({
      params: { section: entry.data.section, slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
if (!entry) throw new Error('entry is required');

const { Content } = await entry.render();

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}

const sectionTitle = SECTION_TITLES[entry.data.section] ?? entry.data.section;
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <section class="layout-main-single hero-layout">
    <p class="terminal-prompt" aria-hidden="true">blog/{entry.data.section} &gt;</p>
    <article class="prose flat-article single-pane">
      <header>
        <p class="meta">{formatDate(entry.data.date)} · {sectionTitle}</p>
        <h1>{entry.data.title}</h1>
      </header>
      <div class="article-content">
        <Content />
      </div>
    </article>
  </section>
</Layout>
