---
import Layout from '../../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { formatDate } from '../../../utils/date';
import { isBlogSection } from '../../../config';

export async function getStaticPaths() {
  const entries = await getCollection('blog');
  return entries
    .filter((e) => !e.data.draft && isBlogSection(e.data.section))
    .map((entry) => ({
      params: { section: entry.data.section, slug: entry.slug },
      props: { entry },
    }));
}

const { entry } = Astro.props;
if (!entry) throw new Error('entry is required');

const { Content } = await entry.render();
---

<Layout title={entry.data.title} description={entry.data.summary}>
  <section class="layout-main-single hero-layout">
    <p class="terminal-prompt" aria-hidden="true">blog/{entry.data.section} &gt;</p>
    <article class="prose flat-article single-pane">
      <header>
        <p class="meta">{formatDate(entry.data.date)}</p>
        <h1>{entry.data.title}</h1>
      </header>
      <div class="article-content">
        <Content />
      </div>
    </article>
  </section>
</Layout>
