---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';
import { SECTION_TITLES } from '../../config';

const entries = await getCollection('blog');
const aboutEntry = entries.find((e) => !e.data.draft && (e.slug === 'about-me' || e.data.section === 'about'));

function formatDate(d: Date): string {
  return d.toLocaleDateString('en-GB', { day: '2-digit', month: 'short', year: 'numeric' });
}

let Content: import('astro').ContentComponent | null = null;
let entryData: { title: string; date: Date; section: string; summary?: string } | null = null;

if (aboutEntry) {
  const rendered = await aboutEntry.render();
  Content = rendered.Content;
  entryData = {
    title: aboutEntry.data.title,
    date: aboutEntry.data.date,
    section: SECTION_TITLES[aboutEntry.data.section] ?? aboutEntry.data.section,
    summary: aboutEntry.data.summary,
  };
}
---

{Content && entryData ? (
  <Layout title={entryData.title} description={entryData.summary}>
    <section class="layout-main-single hero-layout">
      <p class="terminal-prompt" aria-hidden="true">about-me &gt;</p>
      <article class="prose flat-article single-pane">
        <header>
          <p class="meta">{formatDate(entryData.date)} · {entryData.section}</p>
          <h1>{entryData.title}</h1>
        </header>
        <div class="article-content">
          <Content />
        </div>
      </article>
    </section>
  </Layout>
) : (
  <Layout title="Обо мне">
    <section class="layout-main-single hero-layout">
      <p class="terminal-prompt" aria-hidden="true">about-me &gt;</p>
      <article class="prose flat-article single-pane">
        <header>
          <h1>Обо мне</h1>
        </header>
        <div class="article-content">
          <p>Добавь в <code>content/blog/</code> файл <code>about-me.md</code> с frontmatter: <code>section: about</code>, <code>title</code>, <code>date</code>.</p>
        </div>
      </article>
    </section>
  </Layout>
)}
