---
import PageFromEntry from '../../components/PageFromEntry.astro';
import { getCollection } from 'astro:content';
import { SECTION_TITLES } from '../../config';

const pages = (await getCollection('pages')).filter((e) => !e.data.draft);
const aboutEntry = pages.find((e) => e.slug === 'about-me');

let Content: import('astro').ContentComponent | null = null;
let entryData: { data: { title: string; date: Date; summary?: string }; sectionLabel: string } | null = null;

if (aboutEntry) {
  const rendered = await aboutEntry.render();
  Content = rendered.Content;
  entryData = {
    data: aboutEntry.data,
    sectionLabel: SECTION_TITLES['about'] ?? 'Обо мне',
  };
}
---

<PageFromEntry entry={entryData} fallbackTitle="Обо мне" fallbackH1="Обо мне" prompt="about-me &gt;">
  {Content ? <Content /> : <p>Добавь в <code>content/pages/</code> файл <code>about-me.md</code> с frontmatter: <code>title</code>, <code>date</code>.</p>}
</PageFromEntry>
