---
import PageFromEntry from '../components/PageFromEntry.astro';
import { getCollection } from 'astro:content';
import { SECTION_TITLES } from '../config';

const pages = (await getCollection('pages')).filter((e) => !e.data.draft);
const homeEntry = pages.find((e) => e.slug === 'main');

let Content: import('astro').ContentComponent | null = null;
let entryData: { data: { title: string; date: Date; summary?: string }; sectionLabel: string } | null = null;

if (homeEntry) {
  const rendered = await homeEntry.render();
  Content = rendered.Content;
  entryData = {
    data: homeEntry.data,
    sectionLabel: SECTION_TITLES['main'] ?? 'Главная',
  };
}
---

<PageFromEntry entry={entryData} fallbackTitle="Главная" fallbackH1="Главная" prompt="main &gt;">
  {Content ? <Content /> : <p>Добавь в <code>content/pages/</code> файл <code>main.md</code> с frontmatter: <code>title</code>, <code>date</code>.</p>}
</PageFromEntry>
