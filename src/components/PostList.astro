---
import { formatDate } from '../utils/date';
import { BASE } from '../config';

interface Props {
  posts: { slug: string; data: { title: string; date: Date; section: string; summary?: string } }[];
}

const { posts } = Astro.props;
---

<div class="post-list">
  {posts.length === 0 ? (
    <p>Пока ничего нет.</p>
  ) : (
    posts.map((entry) => (
      <div style="margin-bottom: 2rem;">
        <div style="margin-bottom: 0.25rem">
          <p class="meta" style="margin-bottom: 0.15rem; font-size: 0.75rem; opacity: 0.6;">{formatDate(entry.data.date)} · {entry.slug}.md</p>
          <h3 style="margin: 0; font-size: 1.15rem; line-height: 1.3;">
            <a href={`${BASE}blog/${entry.slug}/`} class="post-title-link">
              {entry.data.title}
            </a>
          </h3>
        </div>
        {entry.data.summary && (
          <p style="font-size: 0.8rem; margin-top: 0.35rem; margin-bottom: 0; opacity: 0.8; line-height: 1.4;">
            {entry.data.summary}
          </p>
        )}
      </div>
    ))
  )}
</div>

<style>
  .post-title-link {
    text-decoration: none !important;
    color: var(--pico-contrast) !important;
    transition: all 0.2s ease;
  }

  .post-title-link:hover {
    color: var(--pico-primary) !important;
    text-shadow: 0 0 8px rgba(var(--pico-primary-rgb), 0.4);
  }
</style>
