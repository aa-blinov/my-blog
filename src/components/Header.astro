---
import { SITE } from '../config';
const BASE = import.meta.env.BASE_URL;
---
<header class="site-header wrap">
  <div class="header-left">
    <button type="button" class="nav-menu-btn theme-btn" id="nav-menu-btn" aria-expanded="false" aria-controls="layout-sidebar" aria-label="Открыть меню">
      <span class="nav-icon nav-icon-arrow" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg></span>
    </button>
  </div>
  <a class="brand brand-icon-only" href={BASE} aria-label="На главную"></a>
</header>
