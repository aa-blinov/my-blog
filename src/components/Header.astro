---
import { SITE } from '../config';
const BASE = import.meta.env.BASE_URL;
---
<header class="site-header wrap">
  <a class="brand brand-icon-only" href={BASE} aria-label="На главную"></a>
  <div class="header-right">
    <button type="button" class="nav-menu-btn theme-btn" id="nav-menu-btn" aria-expanded="false" aria-controls="layout-sidebar" aria-label="Открыть меню">
      <span class="nav-icon nav-icon-bars" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5"/></svg></span>
      <span class="nav-icon nav-icon-close" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></span>
    </button>
  </div>
</header>
