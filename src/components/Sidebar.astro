---
import { BASE, SECTION_TITLES } from '../config';
import { formatDate } from '../utils/date';

interface Props {
  blogEntries: { slug: string; title: string; date: Date; section: 'dev' | 'life' }[];
  mainEntry?: { slug: string; title: string; date: Date } | null;
  aboutEntry?: { slug: string; title: string; date: Date } | null;
}

const { blogEntries, mainEntry, aboutEntry } = Astro.props;

const bySection = { dev: [] as typeof blogEntries, life: [] as typeof blogEntries };
blogEntries.forEach((e) => bySection[e.section].push(e));
---

<section class="fs-panel fs-explorer" aria-label="Дерево разделов и статей">
  <div class="fs-search-wrap">
    <div class="fs-tools">
      <input class="fs-search" type="search" placeholder="Search files..." aria-label="Поиск по файлам" />
      <select class="fs-sort" aria-label="Сортировка файлов">
        <option value="date_desc">Новые</option>
        <option value="name_asc">Имя</option>
      </select>
    </div>
    <p class="fs-empty" hidden>Ничего не найдено.</p>
  </div>

  <ul class="fs-tree">
    {mainEntry && (
      <li class="fs-file-item" data-name="main" data-date={Math.floor(mainEntry.date.getTime() / 1000)}>
        <span class="fs-icon fs-icon-file" aria-hidden="true"></span>
        <a class="fs-file-link" href={BASE} title="main.md">main.md</a>
        <span class="fs-meta">{formatDate(mainEntry.date)}</span>
      </li>
    )}
    {aboutEntry && (
      <li class="fs-file-item" data-name="about-me" data-date={Math.floor(aboutEntry.date.getTime() / 1000)}>
        <span class="fs-icon fs-icon-file" aria-hidden="true"></span>
        <a class="fs-file-link" href={`${BASE}about-me/`} title="about-me.md">about-me.md</a>
        <span class="fs-meta">{formatDate(aboutEntry.date)}</span>
      </li>
    )}
    <li class="fs-folder-root">
      <span class="fs-icon fs-icon-folder" aria-hidden="true"></span>
      <span class="fs-folder">blog/</span>
      <ul>
        {(['dev', 'life'] as const).map((section) => (
          <li class="fs-section" data-section={`${BASE}blog/${section}/`}>
            <div class="fs-section-row">
              <button class="fs-toggle" type="button" aria-expanded="true" aria-label={`Свернуть раздел ${SECTION_TITLES[section]}`}>
                <span class="fs-toggle-icon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="14" height="14" fill="currentColor"><path d="M4 6l4 4 4-4"/></svg></span>
              </button>
              <span class="fs-icon fs-icon-folder fs-icon-folder-open" aria-hidden="true"></span>
              <a class="fs-folder-link" href={`${BASE}blog/${section}/`}>{section}/</a>
            </div>
            <ul class="fs-files">
              {bySection[section].map((entry) => (
                  <li class="fs-file-item" data-name={entry.title.toLowerCase()} data-date={Math.floor(entry.date.getTime() / 1000)}>
                    <span class="fs-icon fs-icon-file" aria-hidden="true"></span>
                    <a class="fs-file-link" href={`${BASE}blog/${entry.section}/${entry.slug}/`} title={entry.title}>{entry.title}</a>
                    <span class="fs-meta">{formatDate(entry.date)}</span>
                  </li>
                ))}
            </ul>
          </li>
        ))}
      </ul>
    </li>
  </ul>
</section>
