---
import { BASE, SECTION_TITLES } from '../config';
import { formatDate } from '../utils/date';

interface Props {
  blogEntries: { slug: string; title: string; date: Date; section: 'dev' | 'life' }[];
  mainEntry?: { slug: string; title: string; date: Date } | null;
  aboutEntry?: { slug: string; title: string; date: Date } | null;
}

const { blogEntries, mainEntry, aboutEntry } = Astro.props;

const bySection = { dev: [] as typeof blogEntries, life: [] as typeof blogEntries };
blogEntries.forEach((e) => bySection[e.section].push(e));

// Расчет дат для папок (нужно для сортировки самих папок)
const getSectionStats = (section: 'dev' | 'life') => {
  const dates = bySection[section].map(e => e.date.getTime());
  return {
    min: dates.length ? new Date(Math.min(...dates)).toISOString() : new Date(0).toISOString(),
    max: dates.length ? new Date(Math.max(...dates)).toISOString() : new Date(0).toISOString()
  };
};

const devStats = getSectionStats('dev');
const lifeStats = getSectionStats('life');
const blogStats = {
  min: new Date(Math.min(new Date(devStats.min).getTime(), new Date(lifeStats.min).getTime())).toISOString(),
  max: new Date(Math.max(new Date(devStats.max).getTime(), new Date(lifeStats.max).getTime())).toISOString()
};

// Determine active path
const currentPath = Astro.url.pathname;

function isActive(href: string): boolean {
  const normalize = (p: string) => p.endsWith('/') ? p : p + '/';
  return normalize(currentPath) === normalize(href);
}
---

<nav class="sidebar-nav">
  <div class="sidebar-controls">
    <input
      type="text"
      id="sidebar-search"
      placeholder="search..."
      autocomplete="off"
    />
    <button id="sort-date-btn" class="sort-btn" title="Сортировка по дате">
      <span class="sort-icon">↕</span>
    </button>
  </div>

  <ul id="sidebar-tree" class="sortable-list">
    {mainEntry && (
      <li data-filename="main.md" data-date={mainEntry.date.toISOString()}>
        <span class="file-link-wrapper">
          <a href={BASE} class:list={['file-link', { active: isActive(BASE) }]}>
            <span class="ascii-icon">~</span> main.md
          </a>
          <span class="file-tooltip">main.md</span>
        </span>
        <span class="file-date">{formatDate(mainEntry.date)}</span>
      </li>
    )}
    {aboutEntry && (
      <li data-filename="about-me.md" data-date={aboutEntry.date.toISOString()}>
        <span class="file-link-wrapper">
          <a href={`${BASE}about-me/`} class:list={['file-link', { active: isActive(`${BASE}about-me/`) }]}>
            <span class="ascii-icon">~</span> about-me.md
          </a>
          <span class="file-tooltip">about-me.md</span>
        </span>
        <span class="file-date">{formatDate(aboutEntry.date)}</span>
      </li>
    )}
    
    <li class="folder-item sortable-item" data-date-min={blogStats.min} data-date-max={blogStats.max}>
      <details open>
        <summary class="contrast">
          <span class="ascii-icon folder">▸</span> blog/
        </summary>
        <ul class="sortable-list">
          {(['dev', 'life'] as const).map((section) => {
            const stats = section === 'dev' ? devStats : lifeStats;
            return (
              <li class="folder-item sortable-item" data-date-min={stats.min} data-date-max={stats.max}>
                <details open>
                  <summary class="contrast">
                    <span class="ascii-icon folder">▸</span> {section}/
                  </summary>
                  <ul class="sortable-list">
                    {bySection[section].map((entry) => {
                      const href = `${BASE}blog/${entry.section}/${entry.slug}/`;
                      return (
                        <li class="sortable-item" data-filename={`${entry.slug}.md`} data-date={entry.date.toISOString()}>
                          <span class="file-link-wrapper">
                            <a href={href} class:list={['file-link', { active: isActive(href) }]}>
                              <span class="ascii-icon">~</span> {entry.slug}.md
                            </a>
                            <span class="file-tooltip">{entry.slug}.md</span>
                          </span>
                          <span class="file-date">{formatDate(entry.date)}</span>
                        </li>
                      );
                    })}
                  </ul>
                </details>
              </li>
            );
          })}
        </ul>
      </details>
    </li>
  </ul>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('sidebar-search') as HTMLInputElement;
    const sortBtn = document.getElementById('sort-date-btn');
    const tree = document.getElementById('sidebar-tree');
    if (!searchInput || !sortBtn || !tree) return;

    // --- Транслитерация ---
    const ruToEn: Record<string, string> = {
      'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ё':'yo',
      'ж':'zh','з':'z','и':'i','й':'y','к':'k','л':'l','м':'m',
      'н':'n','о':'o','п':'p','р':'r','с':'s','т':'t','у':'u',
      'ф':'f','х':'kh','ц':'ts','ч':'ch','ш':'sh','щ':'shch',
      'ъ':'','ы':'y','ь':'','э':'e','ю':'yu','я':'ya',
      ' ':'-'
    };
    function transliterate(text: string): string { return text.split('').map(c => ruToEn[c] ?? c).join(''); }
    function hasRussian(text: string): boolean { return /[а-яё]/i.test(text); }

    // --- Поиск ---
    function performSearch() {
      const raw = searchInput.value.toLowerCase().trim();
      const allFileItems = tree.querySelectorAll<HTMLLIElement>('li[data-filename]');
      const allFolderItems = tree.querySelectorAll<HTMLLIElement>('li.folder-item');
      
      localStorage.setItem('sidebar-search', raw);

      if (!raw) {
        allFileItems.forEach(li => li.style.display = '');
        allFolderItems.forEach(li => li.style.display = '');
        return;
      }
      const queries = [raw];
      if (hasRussian(raw)) queries.push(transliterate(raw));
      allFileItems.forEach(li => {
        const name = (li.getAttribute('data-filename') || '').toLowerCase();
        li.style.display = queries.some(q => name.includes(q)) ? '' : 'none';
      });
      allFolderItems.forEach(folder => {
        const visibleFiles = folder.querySelectorAll<HTMLLIElement>('li[data-filename]:not([style*="display: none"])');
        folder.style.display = visibleFiles.length > 0 ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', performSearch);

    // --- Сортировка ---
    type SortOrder = 'none' | 'desc' | 'asc';
    let sortOrder: SortOrder = (localStorage.getItem('sidebar-sort') as SortOrder) || 'none';
    const sortIcon = sortBtn.querySelector('.sort-icon') as HTMLSpanElement;
    const sortStates: Record<SortOrder, { icon: string; title: string; label: string }> = {
      'none': { icon: '↕', title: 'Сортировка по дате', label: '' },
      'desc': { icon: '↓', title: 'Новые сверху', label: 'new' },
      'asc':  { icon: '↑', title: 'Старые сверху', label: 'old' },
    };

    function updateSortUI() {
      const state = sortStates[sortOrder];
      sortIcon.textContent = state.icon;
      sortBtn.setAttribute('title', state.title);
      if (sortOrder === 'none') {
        sortBtn.classList.remove('active');
        sortBtn.removeAttribute('data-label');
      } else {
        sortBtn.classList.add('active');
        sortBtn.setAttribute('data-label', state.label);
      }
    }

    function performSort() {
      localStorage.setItem('sidebar-sort', sortOrder);
      const sortableLists = tree.querySelectorAll<HTMLUListElement>('ul.sortable-list');
      sortableLists.forEach(ul => {
        const items = Array.from(ul.querySelectorAll<HTMLLIElement>(':scope > li.sortable-item'));
        
        items.sort((a, b) => {
          if (sortOrder === 'none') {
            return parseInt(a.getAttribute('data-original-index') || '0') - parseInt(b.getAttribute('data-original-index') || '0');
          }
          const getTime = (el: HTMLLIElement) => {
            if (el.hasAttribute('data-date')) return new Date(el.getAttribute('data-date')!).getTime();
            const attr = sortOrder === 'asc' ? 'data-date-min' : 'data-date-max';
            return new Date(el.getAttribute(attr) || 0).getTime();
          };
          const ta = getTime(a);
          const tb = getTime(b);
          return sortOrder === 'asc' ? ta - tb : tb - ta;
        });

        items.forEach(li => ul.appendChild(li));
      });
    }

    sortBtn.addEventListener('click', () => {
      if (sortOrder === 'none') sortOrder = 'desc';
      else if (sortOrder === 'desc') sortOrder = 'asc';
      else sortOrder = 'none';
      updateSortUI();
      performSort();
    });

    // --- Сброс индекса и восстановление состояния ---
    tree.querySelectorAll<HTMLLIElement>('li.sortable-item').forEach((li, i) => {
      li.setAttribute('data-original-index', String(i));
    });

    // Восстановить поиск если был
    const savedSearch = localStorage.getItem('sidebar-search');
    if (savedSearch) {
      searchInput.value = savedSearch;
      performSearch();
    }

    // Восстановить сортировку если была
    if (sortOrder !== 'none') {
      updateSortUI();
      performSort();
    }
  });
</script>

<style>
  /* --- Панель поиска и сортировки --- */
  .sidebar-controls {
    display: flex;
    align-items: stretch;
    gap: 0.3rem;
    margin-bottom: 0.4rem;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  }

  .sidebar-controls input {
    flex: 1;
    font-size: 0.75rem;
    font-family: inherit;
    padding: 0.2rem 0.4rem;
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 3px;
    background: transparent;
    color: var(--pico-color);
    outline: none;
    margin: 0;
    line-height: 1;
    height: auto;
    box-sizing: border-box;
  }

  .sidebar-controls input::placeholder {
    color: var(--pico-muted-color);
    opacity: 0.6;
  }

  .sidebar-controls input:focus {
    border-color: var(--pico-primary);
  }

  .sort-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent !important;
    background-color: transparent !important;
    border: 1px solid var(--pico-muted-border-color) !important;
    border-radius: 3px !important;
    color: var(--pico-muted-color) !important;
    cursor: pointer;
    padding: 0 0.35rem !important;
    font-size: 0.75rem !important;
    line-height: 1 !important;
    transition: color 0.15s ease, border-color 0.15s ease;
    margin: 0 !important;
    height: auto !important;
    width: auto !important;
    font-family: inherit;
    box-shadow: none !important;
    box-sizing: border-box !important;
  }

  .sort-btn:hover {
    color: var(--pico-primary) !important;
    border-color: var(--pico-primary) !important;
    background: transparent !important;
  }

  .sort-btn.active {
    color: var(--pico-primary) !important;
    border-color: var(--pico-primary) !important;
    background: transparent !important;
  }

  .sort-btn[data-label]::after {
    content: attr(data-label);
    margin-left: 0.15rem;
    font-size: 0.6rem;
    opacity: 0.8;
  }

  /* --- Дерево файлов --- */
  .sidebar-nav {
    position: relative;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
    font-size: 0.8rem;
  }

  .sidebar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .sidebar-nav li {
    margin-bottom: 0;
    line-height: 1;
    padding: 1px 0;
  }

  .sidebar-nav summary {
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: bold;
    margin-bottom: 0;
    line-height: 1;
    padding: 1px 0 !important;
  }

  .sidebar-nav summary::after {
    display: none !important;
  }

  .ascii-icon {
    color: var(--pico-muted-color);
    margin-right: 0.15rem;
  }

  .ascii-icon.folder {
    color: var(--pico-primary);
  }

  .sidebar-nav a.file-link {
    text-decoration: none !important;
    color: var(--pico-contrast) !important;
    transition: color 0.15s ease;
  }

  .sidebar-nav a.file-link:hover {
    color: var(--pico-primary) !important;
  }

  .sidebar-nav a.file-link.active {
    color: var(--pico-primary) !important;
    font-weight: bold;
  }

  .file-tooltip {
    position: absolute;
    left: 0;
    bottom: calc(100% + 4px);
    background: var(--pico-card-background-color);
    color: var(--pico-color);
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 4px;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    font-weight: normal;
    white-space: nowrap;
    pointer-events: none;
    opacity: 0;
    transform: translateY(4px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    z-index: 10;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.12);
  }

  .file-link-wrapper:hover .file-tooltip {
    opacity: 1;
    transform: translateY(0);
  }

  .file-link-wrapper {
    position: relative;
    flex: 1;
    min-width: 0;
    margin-right: 4.5rem;
  }

  .sidebar-nav li:has(> .file-link-wrapper) {
    display: flex;
    align-items: baseline;
  }

  .sidebar-nav .file-link {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-date {
    font-size: 0.7rem;
    opacity: 0.45;
    white-space: nowrap;
    position: absolute;
    right: 0;
    line-height: 1.0;
  }

  details ul {
    padding-left: 0.75rem !important;
    border-left: 1px solid var(--pico-muted-border-color);
    margin-left: 0.2rem !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }

  .sidebar-nav details {
    margin: 0 !important;
    padding: 0 !important;
    position: static !important;
    border: none !important;
  }

  .sidebar-nav details summary {
    margin: 0 !important;
    padding: 0 !important;
    padding-bottom: 0 !important;
    border: none !important;
  }

  .sidebar-nav details > ul {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }
</style>
