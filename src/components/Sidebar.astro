---
import { BASE, SECTION_TITLES } from '../config';
import { formatDate } from '../utils/date';

interface Props {
  blogEntries: { slug: string; title: string; date: Date; section: 'dev' | 'life' }[];
  mainEntry?: { slug: string; title: string; date: Date } | null;
  aboutEntry?: { slug: string; title: string; date: Date } | null;
}

const { blogEntries, mainEntry, aboutEntry } = Astro.props;

const bySection = { dev: [] as typeof blogEntries, life: [] as typeof blogEntries };
blogEntries.forEach((e) => bySection[e.section].push(e));

// Heroicons constants
const docIcon = `
<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
  <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 14.25v-2.625a3.375 3.375 0 0 0-3.375-3.375h-1.5A1.125 1.125 0 0 1 13.5 7.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H8.25m2.25 0H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 0 0-9-9Z" />
</svg>
`;

const folderIcon = `
<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="18" height="18">
  <path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12.75V12A2.25 2.25 0 0 1 4.5 9.75h15A2.25 2.25 0 0 1 21.75 12v.75m-8.69-6.44-2.12-2.12a1.5 1.5 0 0 0-1.06-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.31c-.191 0-.372-.072-.51-.21l-2.12-2.12a1.5 1.5 0 0 0-1.06-.44H4.5A2.25 2.25 0 0 0 2.25 6v12a2.25 2.25 0 0 0 2.25 2.25h15A2.25 2.25 0 0 0 21.75 18V9a2.25 2.25 0 0 0-2.25-2.25h-5.31c-.191 0-.372-.072-.51-.21Z" />
</svg>
`;
---

<nav class="sidebar-nav">
  <ul>
    {mainEntry && (
      <li>
        <a href={BASE} class="contrast">
          <span class="file-icon" set:html={docIcon}></span>
          main.md <span class="file-date">{formatDate(mainEntry.date)}</span>
        </a>
      </li>
    )}
    {aboutEntry && (
      <li>
        <a href={`${BASE}about-me/`} class="contrast">
          <span class="file-icon" set:html={docIcon}></span>
          about-me.md <span class="file-date">{formatDate(aboutEntry.date)}</span>
        </a>
      </li>
    )}
    
    {(['dev', 'life'] as const).map((section) => (
      <li>
        <details open>
          <summary class="contrast">
            <span class="folder-icon" set:html={folderIcon}></span> {section}/
          </summary>
          <ul>
            {bySection[section].map((entry) => (
              <li>
                <a href={`${BASE}blog/${entry.section}/${entry.slug}/`}>
                  <span class="file-icon" set:html={docIcon}></span>
                  {entry.slug}.md <span class="file-date">{formatDate(entry.date)}</span>
                </a>
              </li>
            ))}
          </ul>
        </details>
      </li>
    ))}
  </ul>
</nav>

<style>
  .sidebar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  
  .sidebar-nav li {
    margin-bottom: 0;
    line-height: 1.25;
  }
  
  .sidebar-nav summary {
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: bold;
    margin-bottom: 0;
    display: flex;
    align-items: center;
  }
  
  .sidebar-nav summary::after {
    display: none !important;
  }

  .sidebar-nav a {
    text-decoration: none;
    font-size: 0.9rem;
    display: flex;
    align-items: center;
  }

  .sidebar-nav a:hover {
    text-decoration: underline;
  }

  .file-date {
    font-size: 0.65rem;
    opacity: 0.5;
    margin-left: 0.4rem;
  }

  .file-icon, .folder-icon {
    margin-right: 0.5rem;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    color: var(--pico-muted-color);
  }

  /* Indentation for nested items */
  details ul {
    padding-left: 0.75rem !important;
    border-left: 1px solid var(--pico-muted-border-color);
    margin-left: 0.5rem !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
</style>
