---
import { BASE, type BlogSection } from '../config';
import { formatDate } from '../utils/date';

interface BlogEntry {
  id: string;
  slug: string;
  title: string;
  date: Date;
  section?: string;
}

interface Props {
  blogEntries: BlogEntry[];
  mainEntry?: { slug: string; title: string; date: Date } | null;
  aboutEntry?: { slug: string; title: string; date: Date } | null;
}

const { blogEntries, mainEntry, aboutEntry } = Astro.props;

// --- Tree Building ---
interface TreeNode {
  name: string;
  kind: 'file' | 'folder';
  children?: Record<string, TreeNode>;
  entry?: BlogEntry;
  minDate?: Date;
  maxDate?: Date;
  fullPath?: string;
}

const root: TreeNode = { name: 'blog', kind: 'folder', children: {}, fullPath: '' };

blogEntries.forEach((entry) => {
  // Use frontmatter section as virtual path or fall back to physical path
  const path = entry.section ? `${entry.section}/${entry.id.split('/').pop()}` : entry.id;
  const parts = path.split('/');
  let current = root;

  parts.forEach((part, i) => {
    if (i === parts.length - 1) {
      // It's a file
      current.children![part] = { name: part, kind: 'file', entry };
    } else {
      // It's a folder
      if (!current.children![part]) {
        const folderPath = parts.slice(0, i + 1).join('/');
        current.children![part] = { name: part, kind: 'folder', children: {}, fullPath: folderPath };
      }
      current = current.children![part];
    }
  });
});

// --- Recursive Stats Calculation ---
function calculateStats(node: TreeNode) {
  if (node.kind === 'file') {
    node.minDate = node.entry?.date;
    node.maxDate = node.entry?.date;
    return;
  }

  let min: number | null = null;
  let max: number | null = null;

  Object.values(node.children || {}).forEach((child) => {
    calculateStats(child);
    if (child.minDate) {
      const t = child.minDate.getTime();
      if (min === null || t < min) min = t;
      if (max === null || t > max) max = t;
    }
    if (child.maxDate) {
      const t = child.maxDate.getTime();
      if (min === null || t < min) min = t;
      if (max === null || t > max) max = t;
    }
  });

  if (min !== null) node.minDate = new Date(min);
  if (max !== null) node.maxDate = new Date(max);
}
calculateStats(root);

// Determine active path
const currentPath = Astro.url.pathname;
function isActive(href: string): boolean {
  const normalize = (p: string) => p.endsWith('/') ? p : p + '/';
  return normalize(currentPath) === normalize(href);
}

function getFolderHref(fullPath: string) {
  const cleanPath = fullPath ? `${fullPath}/` : '';
  return `${BASE}blog/${cleanPath}`;
}
---

<nav class="sidebar-nav">
  <div class="sidebar-controls">
    <input
      type="text"
      id="sidebar-search"
      placeholder="search..."
      autocomplete="off"
    />
    <button id="sort-date-btn" class="sort-btn" title="Сортировка по дате">
      <span class="sort-icon">↕</span>
    </button>
  </div>

  <ul id="sidebar-tree" class="sortable-list">
    {mainEntry && (
      <li data-filename="main.md" data-date={mainEntry.date.toISOString()}>
        <span class="file-link-wrapper">
          <a href={BASE} class:list={['file-link', { active: isActive(BASE) }]}>
            <span class="ascii-icon">~</span> main.md
          </a>
        </span>
        <span class="file-date">{formatDate(mainEntry.date)}</span>
      </li>
    )}
    {aboutEntry && (
      <li data-filename="about-me.md" data-date={aboutEntry.date.toISOString()}>
        <span class="file-link-wrapper">
          <a href={`${BASE}about-me/`} class:list={['file-link', { active: isActive(`${BASE}about-me/`) }]}>
            <span class="ascii-icon">~</span> about-me.md
          </a>
        </span>
        <span class="file-date">{formatDate(aboutEntry.date)}</span>
      </li>
    )}
    
    {/* Рекурсивный рендеринг дерева */}
    {function renderTree(node: TreeNode) {
      const childrenArr = Object.values(node.children || {}).sort((a, b) => a.name.localeCompare(b.name));
      
      // Calculate order values for CSS. 
      // We use timestamps in seconds to keep them within safe integer range for CSS.
      // desc: higher date = smaller order value
      // asc: lower date = smaller order value
      const dateVal = node.entry?.date.getTime() || 0;
      const minDateVal = node.minDate?.getTime() || 0;
      const maxDateVal = node.maxDate?.getTime() || 0;
      
      // Base for "none" (alphabetical) is provided by the loop index or just let it be 0
      
      return (
        <li 
          class:list={[{ 'folder-item': node.kind === 'folder', 'sortable-item': true }]} 
          style={{
            '--order-desc': node.kind === 'file' ? -Math.floor(dateVal / 100000) : -Math.floor(maxDateVal / 100000),
            '--order-asc': node.kind === 'file' ? Math.floor(dateVal / 100000) : Math.floor(minDateVal / 100000)
          }}
          data-date-min={node.minDate?.toISOString()} 
          data-date-max={node.maxDate?.toISOString()}
          {...(node.kind === 'file' ? { 
            'data-filename': node.name, 
            'data-date': node.entry?.date.toISOString() 
          } : {})}
        >
          {node.kind === 'folder' ? (
            <details open>
              <summary class="contrast">
                <span class="ascii-icon folder">▸</span>
                <a 
                  href={getFolderHref(node.fullPath || '')} 
                  class:list={['folder-link', { active: isActive(getFolderHref(node.fullPath || '')) }]}
                >
                  {node.name}/
                </a>
              </summary>
              <ul class="sortable-list">
                {childrenArr.map(child => renderTree(child))}
              </ul>
            </details>
          ) : (
            <>
              <span class="file-link-wrapper">
                <a href={`${BASE}blog/${node.entry?.slug}/`} class:list={['file-link', { active: isActive(`${BASE}blog/${node.entry?.slug}/`) }]}>
                  <span class="ascii-icon">~</span> {node.name}
                </a>
              </span>
              <span class="file-date">{formatDate(node.entry!.date)}</span>
            </>
          )}
        </li>
      );
    }(root)}
  </ul>

  <!-- Synchronous state restoration to prevent blinking -->
  <script is:inline>
    (function() {
      const tree = document.getElementById('sidebar-tree');
      const sortBtn = document.getElementById('sort-date-btn');
      const searchInput = document.getElementById('sidebar-search');
      if (!tree || !sortBtn || !searchInput) return;

      try {
        // --- Restore Sort State ---
        const sortOrder = localStorage.getItem('sidebar-sort') || 'none';
        if (sortOrder !== 'none') {
          tree.setAttribute('data-sort', sortOrder);
          const icon = sortBtn.querySelector('.sort-icon');
          if (icon) {
            if (sortOrder === 'desc') {
              icon.textContent = '↓';
              sortBtn.setAttribute('title', 'Новые сверху');
              sortBtn.classList.add('active');
              sortBtn.setAttribute('data-label', 'new');
            } else if (sortOrder === 'asc') {
              icon.textContent = '↑';
              sortBtn.setAttribute('title', 'Старые сверху');
              sortBtn.classList.add('active');
              sortBtn.setAttribute('data-label', 'old');
            }
          }
        }

        // --- Restore Search State ---
        const searchRaw = localStorage.getItem('sidebar-search');
        if (searchRaw) {
          const raw = searchRaw.toLowerCase().trim();
          searchInput.value = searchRaw; // Restore input value
          if (raw) {
            const ruToEn = {
              'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ё':'yo',
              'ж':'zh','з':'z','и':'i','й':'y','к':'k','л':'l','м':'m',
              'н':'n','о':'o','п':'p','р':'r','с':'s','т':'t','у':'u',
              'ф':'f','х':'kh','ц':'ts','ч':'ch','ш':'sh','щ':'shch',
              'ъ':'','ы':'y','ь':'','э':'e','ю':'yu','я':'ya',
              ' ':'-'
            };
            const transliterate = (text) => text.split('').map(c => ruToEn[c] ?? c).join('');
            const hasRussian = (text) => /[а-яё]/i.test(text);

            const allFileItems = tree.querySelectorAll('li[data-filename]');
            const allFolderItems = tree.querySelectorAll('li.folder-item');
            
            const queries = [raw];
            if (hasRussian(raw)) queries.push(transliterate(raw));
            
            allFileItems.forEach(li => {
              const name = (li.getAttribute('data-filename') || '').toLowerCase();
              li.style.display = queries.some(q => name.includes(q)) ? '' : 'none';
            });
            allFolderItems.forEach(folder => {
              const visibleFiles = folder.querySelectorAll('li[data-filename]:not([style*="display: none"])');
              folder.style.display = visibleFiles.length > 0 ? '' : 'none';
            });
          }
        }
      } catch (e) {
        // Ignore localStorage or other early errors
      }
    })();
  </script>
</nav>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const searchInput = document.getElementById('sidebar-search') as HTMLInputElement;
    const sortBtn = document.getElementById('sort-date-btn');
    const tree = document.getElementById('sidebar-tree');
    if (!searchInput || !sortBtn || !tree) return;

    // --- Folder link handling (prevent toggle on name click) ---
    tree.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const folderLink = target.closest('.folder-link');
      if (folderLink) {
        e.stopPropagation();
      }
    }, true);

    // --- Транслитерация ---
    const ruToEn: Record<string, string> = {
      'а':'a','б':'b','в':'v','г':'g','д':'d','е':'e','ё':'yo',
      'ж':'zh','з':'z','и':'i','й':'y','к':'k','л':'l','м':'m',
      'н':'n','о':'o','п':'p','р':'r','с':'s','т':'t','у':'u',
      'ф':'f','х':'kh','ц':'ts','ч':'ch','ш':'sh','щ':'shch',
      'ъ':'','ы':'y','ь':'','э':'e','ю':'yu','я':'ya',
      ' ':'-'
    };
    function transliterate(text: string): string { return text.split('').map(c => ruToEn[c] ?? c).join(''); }
    function hasRussian(text: string): boolean { return /[а-яё]/i.test(text); }

    // --- Поиск ---
    function performSearch() {
      const raw = searchInput.value.toLowerCase().trim();
      const allFileItems = tree!.querySelectorAll<HTMLLIElement>('li[data-filename]');
      const allFolderItems = tree!.querySelectorAll<HTMLLIElement>('li.folder-item');
      
      localStorage.setItem('sidebar-search', raw);

      if (!raw) {
        allFileItems.forEach(li => li.style.display = '');
        allFolderItems.forEach(li => li.style.display = '');
        return;
      }
      const queries = [raw];
      if (hasRussian(raw)) queries.push(transliterate(raw));
      allFileItems.forEach(li => {
        const name = (li.getAttribute('data-filename') || '').toLowerCase();
        li.style.display = queries.some(q => name.includes(q)) ? '' : 'none';
      });
      allFolderItems.forEach(folder => {
        const visibleFiles = folder.querySelectorAll<HTMLLIElement>('li[data-filename]:not([style*="display: none"])');
        folder.style.display = visibleFiles.length > 0 ? '' : 'none';
      });
    }

    searchInput.addEventListener('input', performSearch);

    // --- Закрытие сайдбара при клике на мобилках ---
    tree.addEventListener('click', (e) => {
      const target = e.target as HTMLElement;
      const link = target.closest('a');
      if (link && window.innerWidth < 992) {
        const sidebar = document.getElementById('layout-sidebar');
        if (sidebar && sidebar.classList.contains('sidebar-shown')) {
          sidebar.classList.remove('sidebar-shown');
          window.dispatchEvent(new CustomEvent('sidebar-state-changed'));
        }
      }
    });

    // --- Сортировка ---
    type SortOrder = 'none' | 'desc' | 'asc';
    let sortOrder: SortOrder = (localStorage.getItem('sidebar-sort') as SortOrder) || 'none';
    const sortIcon = sortBtn.querySelector('.sort-icon') as HTMLSpanElement;
    const sortStates: Record<SortOrder, { icon: string; title: string; label: string }> = {
      'none': { icon: '↕', title: 'Сортировка по дате', label: '' },
      'desc': { icon: '↓', title: 'Новые сверху', label: 'new' },
      'asc':  { icon: '↑', title: 'Старые сверху', label: 'old' },
    };

    function updateSortUI() {
      const state = sortStates[sortOrder];
      sortIcon.textContent = state.icon;
      sortBtn!.setAttribute('title', state.title);
      if (sortOrder === 'none') {
        sortBtn!.classList.remove('active');
        sortBtn!.removeAttribute('data-label');
      } else {
        sortBtn!.classList.add('active');
        sortBtn!.setAttribute('data-label', state.label);
      }
      
      // Update global sort attribute on the list for CSS sorting
      tree!.setAttribute('data-sort', sortOrder);
    }

    sortBtn.addEventListener('click', () => {
      if (sortOrder === 'none') sortOrder = 'desc';
      else if (sortOrder === 'desc') sortOrder = 'asc';
      else sortOrder = 'none';
      localStorage.setItem('sidebar-sort', sortOrder);
      updateSortUI();
    });
  });
</script>

<style>
  /* --- Панель поиска и сортировки --- */
  .sidebar-controls {
    display: flex;
    align-items: stretch;
    gap: 0.3rem;
    margin-bottom: 0.4rem;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
  }

  .sidebar-controls input {
    flex: 1;
    font-size: 0.75rem;
    font-family: inherit;
    padding: 0.2rem 0.4rem;
    border: 1px solid var(--pico-muted-border-color);
    border-radius: 3px;
    background: transparent;
    color: var(--pico-color);
    outline: none;
    margin: 0;
    line-height: 1;
    height: auto;
    box-sizing: border-box;
  }

  .sidebar-controls input::placeholder {
    color: var(--pico-muted-color);
    opacity: 0.6;
  }

  .sidebar-controls input:focus {
    border-color: var(--pico-primary);
  }

  .sort-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent !important;
    background-color: transparent !important;
    border: 1px solid var(--pico-muted-border-color) !important;
    border-radius: 3px !important;
    color: var(--pico-muted-color) !important;
    cursor: pointer;
    padding: 0 0.35rem !important;
    font-size: 0.75rem !important;
    line-height: 1 !important;
    transition: color 0.15s ease, border-color 0.15s ease;
    margin: 0 !important;
    height: auto !important;
    width: auto !important;
    font-family: inherit;
    box-shadow: none !important;
    box-sizing: border-box !important;
  }

  .sort-btn:hover {
    color: var(--pico-primary) !important;
    border-color: var(--pico-primary) !important;
    background: transparent !important;
  }

  .sort-btn.active {
    color: var(--pico-primary) !important;
    border-color: var(--pico-primary) !important;
    background: transparent !important;
  }

  .sort-btn[data-label]::after {
    content: attr(data-label);
    margin-left: 0.15rem;
    font-size: 0.6rem;
    opacity: 0.8;
  }

  /* --- Дерево файлов --- */
  .sidebar-nav {
    position: relative;
    font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', 'Consolas', monospace;
    font-size: 0.8rem;
  }

  .sidebar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
  }
  
  /* CSS-based sorting logic */
  .sortable-list[data-sort="desc"] > .sortable-item {
    order: var(--order-desc, 0);
  }
  .sortable-list[data-sort="asc"] > .sortable-item {
    order: var(--order-asc, 0);
  }

  .sidebar-nav li {
    margin-bottom: 0;
    line-height: 1;
    padding: 1px 0;
  }

  .sidebar-nav summary {
    cursor: pointer;
    font-size: 0.8rem;
    font-weight: bold;
    margin-bottom: 0;
    line-height: 1;
    padding: 1px 0 !important;
  }

  .sidebar-nav summary::after {
    display: none !important;
  }

  .ascii-icon {
    color: var(--pico-muted-color);
    margin-right: 0.2rem;
    flex-shrink: 0;
  }

  .ascii-icon.folder {
    color: var(--pico-primary);
    padding: 0 0.1rem;
    cursor: pointer;
  }

  .sidebar-nav a.file-link {
    text-decoration: none !important;
    color: var(--pico-contrast) !important;
    transition: all 0.15s ease;
    display: flex;
    align-items: center;
    padding: 2px 4px;
    margin: 0 -4px;
    border-radius: 3px;
  }

  .sidebar-nav first-child a.file-link {
    margin-left: 0;
  }

  .sidebar-nav a.file-link:hover {
    color: var(--pico-primary) !important;
    background-color: var(--pico-code-background-color) !important;
  }

  .sidebar-nav a.file-link.active {
    color: var(--pico-primary) !important;
    font-weight: bold;
    background-color: rgba(var(--pico-primary-rgb), 0.1) !important;
  }

  /* --- Folder Links --- */
  .sidebar-nav a.folder-link {
    text-decoration: none !important;
    color: inherit !important;
    transition: all 0.15s ease;
    display: inline-flex;
    align-items: center;
    padding: 2px 4px;
    margin: 0 -4px;
    border-radius: 3px;
    width: auto;
  }

  .sidebar-nav a.folder-link:hover {
    color: var(--pico-primary) !important;
    background-color: var(--pico-code-background-color) !important;
  }

  .sidebar-nav a.folder-link.active {
    color: var(--pico-primary) !important;
    font-weight: bold;
    background-color: rgba(var(--pico-primary-rgb), 0.1) !important;
  }

  .file-link-wrapper {
    position: relative;
    flex: 1;
    min-width: 0;
  }

  .sidebar-nav li:has(> .file-link-wrapper) {
    display: flex;
    align-items: baseline;
  }

  .sidebar-nav .file-link {
    display: block;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .file-date {
    font-size: 0.7rem;
    opacity: 0.45;
    white-space: nowrap;
    position: absolute;
    right: 0;
    line-height: 1.7;
  }

  details ul {
    padding-left: 0.75rem !important;
    border-left: 1px solid var(--pico-muted-border-color);
    margin-left: 0.2rem !important;
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }

  .sidebar-nav details {
    margin: 0 !important;
    padding: 0 !important;
    position: static !important;
    border: none !important;
  }

  .sidebar-nav details summary {
    margin: 0 !important;
    padding: 0 !important;
    padding-bottom: 0 !important;
    border: none !important;
  }

  .sidebar-nav details > ul {
    margin-top: 0 !important;
    padding-top: 0 !important;
  }

  @media (max-width: 991px) {
    .sidebar-nav {
      font-size: 1rem;
    }
    .sidebar-controls input {
      font-size: 0.9rem;
      padding: 0.6rem 0.8rem;
      height: 44px; /* Larger tap target */
    }
    .sort-btn {
      height: 44px !important;
      width: 44px !important;
      font-size: 1.1rem !important;
    }
    .sidebar-nav a.file-link, 
    .sidebar-nav a.folder-link, 
    .sidebar-nav summary {
      font-size: 1rem;
      padding: 6px 4px;
    }
    .file-date {
      font-size: 1rem;
    }
  }
</style>
