---
import { BASE } from '../config';

interface Props {
  breadcrumbPath: string;
}

const { breadcrumbPath } = Astro.props;
---
<nav class="site-navbar top-bar-breadcrumb" role="banner" aria-label="Навигация">
  <div class="header-left">
    <button type="button" class="nav-menu-btn theme-btn" id="nav-menu-btn" aria-expanded="false" aria-controls="layout-sidebar" aria-label="Открыть меню">
      <span class="nav-icon nav-icon-arrow" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"/></svg></span>
    </button>
  </div>
  <a class="brand brand-icon-only" href={BASE} aria-label="На главную"></a>
  <div class="navbar-breadcrumb-wrap">
    <span class="top-bar-text">content/</span>
    <span class="top-bar-sep" aria-hidden="true"> · </span>
    <span class="top-bar-path">{breadcrumbPath}</span>
  </div>
  <div class="theme-controls-in-bar" aria-label="Размер шрифта и тема">
    <span class="font-size-controls" aria-label="Размер шрифта">
      <button id="font-size-decrease" type="button" class="font-size-btn" aria-label="Уменьшить шрифт">A−</button>
      <button id="font-size-increase" type="button" class="font-size-btn" aria-label="Увеличить шрифт">A+</button>
    </span>
    <button id="theme-toggle" type="button" class="theme-btn theme-btn-icon" aria-label="Переключить тему">
      <span class="theme-icon theme-icon-sun" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386l-1.591 1.591M21 12h-2.25m-.386 6.364l-1.591-1.591M12 18.75V21m-4.773-4.227l-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0z"/></svg></span>
      <span class="theme-icon theme-icon-moon" aria-hidden="true"><svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="20" height="20"><path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0118 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 003 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 009.002-5.998z"/></svg></span>
    </button>
  </div>
</nav>
