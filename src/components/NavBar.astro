---
import { BASE } from '../config';

interface Props {
  breadcrumbPath: string;
}

const { breadcrumbPath } = Astro.props;
---
<nav class="vertical-navbar">
  <ul>
    <!-- Sidebar toggle: only visible on mobile -->
    <li class="mobile-only">
      <button id="sidebar-toggle" aria-label="Toggle sidebar">
        <!-- Heroicons: Bars 3 (hamburger) -->
        <svg id="sidebar-open-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 6.75h16.5M3.75 12h16.5m-16.5 5.25h16.5" />
        </svg>
        <!-- Heroicons: X Mark (close) -->
        <svg id="sidebar-close-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24" style="display:none">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6 18 18 6M6 6l12 12" />
        </svg>
      </button>
    </li>
    <li>
      <a href={BASE} aria-label="Home">
        <!-- Heroicons: Home (Outline) -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="m2.25 12 8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25" />
        </svg>
      </a>
    </li>

  </ul>

  <!-- Theme toggle: top-right on mobile (via CSS), bottom on desktop -->
  <ul class="bottom-nav">
    <!-- Font Size Controls -->
    <li>
      <button id="font-increase" class="contrast" aria-label="Increase font size" style="color: inherit;">
        <!-- Plus Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15" />
        </svg>
      </button>
    </li>
    <li>
      <button id="font-decrease" class="contrast" aria-label="Decrease font size" style="color: inherit;">
        <!-- Minus Icon -->
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor" width="20" height="20">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14" />
        </svg>
      </button>
    </li>

    <!-- Theme Toggle -->
    <li>
      <button id="theme-toggle" class="contrast" aria-label="Toggle theme" style="color: inherit;">
        <!-- Heroicons: Sun (Outline) -->
        <svg id="sun-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v2.25m6.364.386-1.591 1.591M21 12h-2.25m-.386 6.364-1.591-1.591M12 18.75V21m-4.773-4.227-1.591 1.591M5.25 12H3m4.227-4.773L5.636 5.636M15.75 12a3.75 3.75 0 1 1-7.5 0 3.75 3.75 0 0 1 7.5 0Z" />
        </svg>
        <!-- Heroicons: Moon (Outline) -->
        <svg id="moon-icon" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="24" height="24">
          <path stroke-linecap="round" stroke-linejoin="round" d="M21.752 15.002A9.718 9.718 0 0 1 18 15.75c-5.385 0-9.75-4.365-9.75-9.75 0-1.33.266-2.597.748-3.752A9.753 9.753 0 0 0 3 11.25C3 16.635 7.365 21 12.75 21a9.753 9.753 0 0 0 9.002-5.998Z" />
        </svg>
      </button>
    </li>
  </ul>
</nav>

<script>
  const sidebarToggle = document.getElementById('sidebar-toggle');
  const sidebar = document.getElementById('layout-sidebar');
  const openIcon = document.getElementById('sidebar-open-icon');
  const closeIcon = document.getElementById('sidebar-close-icon');
  const root = document.documentElement;
  const body = document.body;
  const mobileBreakpoint = 992;
  let lockedScrollY = 0;

  function isMobileViewport() {
    return window.innerWidth < mobileBreakpoint;
  }

  function lockPageScroll() {
    if (!body || body.dataset.sidebarScrollLocked === 'true') return;

    lockedScrollY = window.scrollY;
    body.dataset.sidebarScrollLocked = 'true';
    root.classList.add('sidebar-open');
    body.classList.add('sidebar-open');
    body.style.position = 'fixed';
    body.style.top = `-${lockedScrollY}px`;
    body.style.left = '0';
    body.style.right = '0';
    body.style.width = '100%';
  }

  function unlockPageScroll() {
    if (!body) return;

    const wasLocked = body.dataset.sidebarScrollLocked === 'true';
    const offsetTop = body.style.top;

    delete body.dataset.sidebarScrollLocked;
    root.classList.remove('sidebar-open');
    body.classList.remove('sidebar-open');
    body.style.position = '';
    body.style.top = '';
    body.style.left = '';
    body.style.right = '';
    body.style.width = '';

    if (wasLocked) {
      const restoreY = offsetTop ? Math.abs(parseInt(offsetTop, 10)) || lockedScrollY : lockedScrollY;
      window.scrollTo(0, restoreY);
    }
  }
 
  function syncIcons() {
    const isShown = sidebar?.classList.contains('sidebar-shown');
    const isMobile = isMobileViewport();
    
    if (openIcon && closeIcon) {
      if (isMobile) {
        openIcon.style.display = isShown ? 'none' : 'block';
        closeIcon.style.display = isShown ? 'block' : 'none';
      } else {
        const isHidden = sidebar?.classList.contains('sidebar-hidden');
        openIcon.style.display = isHidden ? 'block' : 'none';
        closeIcon.style.display = isHidden ? 'none' : 'block';
      }
    }
  }

  function syncMobileSidebarState() {
    if (!sidebar) return;

    if (!isMobileViewport()) {
      sidebar.classList.remove('sidebar-shown');
      unlockPageScroll();
      syncIcons();
      return;
    }

    sidebar.classList.remove('sidebar-hidden');

    if (sidebar.classList.contains('sidebar-shown')) lockPageScroll();
    else unlockPageScroll();

    syncIcons();
  }

  function notifySidebarStateChanged() {
    window.dispatchEvent(new CustomEvent('sidebar-state-changed'));
  }

  syncMobileSidebarState();
  window.addEventListener('resize', syncMobileSidebarState);
  window.addEventListener('sidebar-state-changed', syncMobileSidebarState);

  sidebarToggle?.addEventListener('click', () => {
    const isMobile = isMobileViewport();
    if (isMobile) {
      sidebar?.classList.remove('sidebar-hidden');
      sidebar?.classList.toggle('sidebar-shown');
    } else {
      sidebar?.classList.remove('sidebar-shown');
      sidebar?.classList.toggle('sidebar-hidden');
    }
    notifySidebarStateChanged();
  });
</script>

<style>
  /* Local styling only for vertical-navbar list resets */
  .vertical-navbar ul {
    list-style: none !important;
    margin: 0 !important;
    padding: 0 !important;
  }
</style>
